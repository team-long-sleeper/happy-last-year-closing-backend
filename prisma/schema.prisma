// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  name          String
  profileImage  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLoginAt   DateTime
  oauthAccounts OAuthAccount[]

  contacts        Contact[]        @relation("OwnerContacts")
  linkedContacts  Contact[]        @relation("LinkedUser")
  friends         Friendship[]     @relation("UserFriends")
  friendOf        Friendship[]     @relation("FriendOf")
  refreshSessions RefreshSession[]
  episodes        Episode[]        @relation("EpisodeOwner")
  placeFavorites  PlaceFavorite[]
}

model OAuthAccount {
  id                String        @id @default(uuid())
  provider          OAuthProvider
  providerUserId    String
  userId            String
  oauthAccessToken  String?
  oauthRefreshToken String?
  expiresAt         DateTime?
  user              User          @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
}

enum OAuthProvider {
  KAKAO
  GOOGLE
  NAVER
}

model Contact {
  id             String         @id @default(uuid())
  ownerUserId    String
  name           String
  provider       OAuthProvider?
  providerUserId String?
  linkedUserId   String?
  createdAt      DateTime       @default(now())
  profileImage   String?

  owner      User  @relation("OwnerContacts", fields: [ownerUserId], references: [id], onDelete: Cascade)
  linkedUser User? @relation("LinkedUser", fields: [linkedUserId], references: [id])

  episodes EpisodeMate[]

  @@unique([ownerUserId, provider, providerUserId])
}

model EpisodeMate {
  episodeId Int
  contactId String

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([episodeId, contactId])
}

model Friendship {
  id           String           @id @default(uuid())
  userId       String
  friendUserId String
  status       FriendshipStatus
  createdAt    DateTime         @default(now())

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOf", fields: [friendUserId], references: [id], onDelete: Cascade)

  @@unique([userId, friendUserId])
}

enum FriendshipStatus {
  pending
  accepted
  blocked
}

model RefreshSession {
  id        Int    @id @default(autoincrement())
  userId    String
  tokenHash String

  sessionKey String?

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?

  ip        String?
  userAgent String?

  lastIP        String?
  lastUserAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@unique([sessionKey])
  @@index([userId]) // note 이게 무슨 뜻이지
}

model EpisodePicture {
  id        Int    @id @default(autoincrement())
  episodeId Int
  key       String
  order     Int

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([episodeId, order])
  @@index([episodeId])
}

enum PlaceProvider {
  KAKAO
  NAVER
}

model Place {
  id         Int      @id @default(autoincrement())
  providerId String   @unique
  name       String
  address    String
  lat        Float
  lng        Float
  createdAt  DateTime @default(now())
  url        String

  favorites PlaceFavorite[]
  episodes  Episode[]

  @@index([lat, lng])
}

model PlaceFavorite {
  id          Int    @id @default(autoincrement())
  placeId     Int
  ownerUserId String

  aliasName String
  createdAt DateTime @default(now())

  owner User  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, placeId])
  @@index([ownerUserId, aliasName])
}

model Episode {
  id Int @id @default(autoincrement())

  ownerUserId String
  owner       User             @relation("EpisodeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  date        DateTime
  title       String
  memo        String           @default("")
  mates       EpisodeMate[]
  placeId     Int
  place       Place            @relation(fields: [placeId], references: [id])
  pictures    EpisodePicture[]
  createdAt   DateTime         @default(now())
}
